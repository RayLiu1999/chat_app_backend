        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "WS Connections / Rooms / Message Rate over Time",
      "datasource": "Prometheus",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 50 },
      "targets": [
        {
          "expr": "sum(chat_ws_active_connections{job=~\"$job\",instance=~\"$instance\"}) or vector(0)",
          "legendFormat": "WS connections",
          "refId": "A"
        },
        {
          "expr": "sum(chat_active_rooms{job=~\"$job\",instance=~\"$instance\"}) or vector(0)",
          "legendFormat": "active rooms",
          "refId": "B"
        },
        {
          "expr": "sum(rate(chat_messages_saved_total{job=~\"$job\",instance=~\"$instance\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "msg/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "msg/s" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ],
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"]
