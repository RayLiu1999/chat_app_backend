      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 43 },
      "targets": [
        {
          "expr": "sum(chat_active_rooms{job=~\"$job\",instance=~\"$instance\"}) or vector(0)",
          "legendFormat": "rooms",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
